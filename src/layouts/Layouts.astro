---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const { title, description = "Shop Kloset Inc.公式サイト。ブランド情報、プロジェクト、ニュースなどを紹介。" } = Astro.props;

const locale = Astro.currentLocale || "ja"; 
const { pathname } = Astro.url;

const isHome = pathname === `/${locale}/` || pathname === `/${locale}`;

const siteUrl = "https://shopkloset.com";
const canonical = `${siteUrl}${pathname}`;
---

<html lang={locale}>
<head>

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta name="generator" content={Astro.generator} />

<title>{title ? `${title} | Shop Kloset Inc.` : "Shop Kloset Inc. Official Website"}</title>
<meta name="description" content={description} />

<meta name="robots" content="index, follow" />
<meta name="theme-color" content="#000000" />

<link rel="canonical" href={canonical} />

<link rel="alternate" hreflang="ja" href={`${siteUrl}/ja${pathname.replace(/^\/(ja|en|ko)/, '')}`} />
<link rel="alternate" hreflang="en" href={`${siteUrl}/en${pathname.replace(/^\/(ja|en|ko)/, '')}`} />
<link rel="alternate" hreflang="ko" href={`${siteUrl}/ko${pathname.replace(/^\/(ja|en|ko)/, '')}`} />
<link rel="alternate" hreflang="x-default" href={`${siteUrl}/ja/`} />

<!-- OGP -->
<meta property="og:site_name" content="Shop Kloset Inc." />
<meta property="og:title" content={title || "Shop Kloset Inc."} />
<meta property="og:description" content={description} />
<meta property="og:type" content="website" />
<meta property="og:url" content={canonical} />
<meta property="og:image" content="https://shopkloset.com/og-image.jpg" />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content="@ShopKloset" />
<meta name="twitter:title" content={title || "Shop Kloset Inc."} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content="https://shopkloset.com/og-image.jpg" />

<!-- Favicon -->
<link rel="icon" type="image/svg+xml" href="/skinc_favicon.svg" />
<link rel="alternate icon" href="/favicon.ico" />
<link rel="apple-touch-icon" href="/skinc_favicon-256.png" />

<!-- DNS Prefetch -->
<link rel="dns-prefetch" href="//fonts.googleapis.com">
<link rel="dns-prefetch" href="//fonts.gstatic.com">

<!-- Preconnect -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700;900&display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700;900&display=swap" rel="stylesheet">

<!-- Organization Schema -->
<script type="application/ld+json">
{
 "@context": "https://schema.org",
 "@type": "Organization",
 "name": "Shop Kloset Inc.",
 "url": "https://shopkloset.com/",
 "logo": "https://shopkloset.com/skinc_favicon-256.png",
 "description": "Shop Kloset Inc. Official Website",
 "foundingDate": "2021-01",
 "founder": {
   "@type": "Person",
   "name": "Kuniyuki Sakurai"
 },
 "address": {
   "@type": "PostalAddress",
   "streetAddress": "1-16-7",
   "addressLocality": "Jinnan, Shibuya-ku",
   "addressRegion": "Tokyo",
   "postalCode": "150-0041",
   "addressCountry": "JP"
 },
 "sameAs": [
   "https://www.instagram.com/shopkloset_official",
   "https://www.tiktok.com/@shopkloset_official",
   "https://x.com/ShopKloset",
   "https://www.youtube.com/@ShopKloset"
 ]
}
</script>

<!-- WebSite Schema -->
<script type="application/ld+json">
{
 "@context": "https://schema.org",
 "@type": "WebSite",
 "name": "Shop Kloset Inc.",
 "url": "https://shopkloset.com/"
}
</script>

</head>

<body class:list={[{ home: isHome }]}>

<slot name="header" />

<slot />

<slot name="footer" />

</body>
</html>
